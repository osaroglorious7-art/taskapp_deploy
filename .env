# COMMITTED deploy state for the GitOps stack (non-secret only).
#
# Portainer reads this .env alongside docker-compose.prod.yml. CI rewrites the
# *_TAG lines below to the new commit SHA on every push to main; Portainer's git
# polling then sees the change and redeploys with the new image.
#
# DO NOT put POSTGRES_PASSWORD / SECRET_KEY here — set those as Portainer STACK
# ENVIRONMENT VARIABLES (UI), which override/extend this file at deploy time.

REGISTRY=ghcr.io
# CI publishes via GITHUB_TOKEN from the ts-a-devops repos, so packages live there.
IMAGE_OWNER=ts-a-devops

# --- managed by CI (GitOps): pinned to the commit SHA on every deploy ---
BACKEND_TAG=5d6b8fc
FRONTEND_TAG=26da2b0

# Non-secret DB identifiers (the PASSWORD is a Portainer stack env var)
POSTGRES_USER=taskapp_user
POSTGRES_DB=taskapp

# CORS allowlist for the API (non-secret). Set to the frontend origin.
CORS_ORIGINS=https://devops-tsacademy.com
