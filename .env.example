# Reference for taskapp_deploy/.env and the Portainer stack env vars.
#
# TWO sets of variables, deliberately kept apart:
#
# 1) COMMITTED to git in .env (non-secret) — CI updates the *_TAG lines:
REGISTRY=ghcr.io
IMAGE_OWNER=ts-a-devops
BACKEND_TAG=latest
FRONTEND_TAG=latest
POSTGRES_USER=taskapp_user
POSTGRES_DB=taskapp

# 2) SET IN PORTAINER (Stack -> Environment variables), NEVER committed:
#    POSTGRES_PASSWORD=<strong random password>
#    SECRET_KEY=<python -c "import secrets; print(secrets.token_hex(32))">
